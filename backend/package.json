{
    "name": "backend",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "tsx watch --env-file=.env src/index.ts",
        "build": "tsc",
        "start": "node --env-file=.env dist/index.js",
        "start:prod": "node dist/index.js",
        "format": "prettier --write .",
        "gen:api": "tsx --env-file=.env scripts/gen-openapi.ts",
        "db:dev": "source .env && psql $DATABASE_URL -c \"DROP SCHEMA public CASCADE\" && psql $DATABASE_URL -c \"CREATE SCHEMA public\" && psql $DATABASE_URL -f migrations.sql",
        "s3:bucket": "source .env && docker run --rm --network host --entrypoint sh minio/mc -c \"mc alias set local $S3_ENDPOINT $S3_ACCESS_KEY $S3_SECRET_KEY && mc mb --ignore-existing local/$S3_BUCKET\""
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1007.0",
        "@hono/node-server": "^1.19.11",
        "@hono/zod-openapi": "^1.2.2",
        "hono": "^4.12.7",
        "pg": "^8.13.3",
        "sharp": "^0.34.5",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^22.13.10",
        "@types/pg": "^8.11.11",
        "@types/sharp": "^0.31.1",
        "prettier": "3.8.1",
        "tsx": "^4.19.3",
        "typescript": "^5.8.2"
    }
}
