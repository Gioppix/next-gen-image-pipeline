{
    "openapi": "3.0.0",
    "info": { "title": "Next-Gen Image Pipeline API", "version": "1.0.0" },
    "components": { "schemas": {}, "parameters": {} },
    "paths": {
        "/transformations": {
            "get": {
                "responses": {
                    "200": {
                        "description": "All jobs",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "jobs": {
                                            "type": "array",
                                            "items": {
                                                "type": "object",
                                                "properties": {
                                                    "job_id": {
                                                        "type": "string",
                                                        "format": "uuid"
                                                    },
                                                    "status": { "type": "string" },
                                                    "submitted_at": { "type": "string" },
                                                    "completed_at": {
                                                        "type": "string",
                                                        "nullable": true
                                                    },
                                                    "error_msg": {
                                                        "type": "string",
                                                        "nullable": true
                                                    },
                                                    "original_image_id": {
                                                        "type": "string",
                                                        "format": "uuid"
                                                    },
                                                    "final_image_id": {
                                                        "type": "string",
                                                        "nullable": true,
                                                        "format": "uuid"
                                                    }
                                                },
                                                "required": [
                                                    "job_id",
                                                    "status",
                                                    "submitted_at",
                                                    "completed_at",
                                                    "error_msg",
                                                    "original_image_id",
                                                    "final_image_id"
                                                ]
                                            }
                                        }
                                    },
                                    "required": ["jobs"]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/transformations/create": {
            "post": {
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "type": "object",
                                "properties": { "file": { "nullable": true } }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Job created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "job_id": { "type": "string", "format": "uuid" }
                                    },
                                    "required": ["job_id"]
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": { "error": { "type": "string" } },
                                    "required": ["error"]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/transformations/{id}/status": {
            "get": {
                "parameters": [
                    {
                        "schema": { "type": "string", "format": "uuid" },
                        "required": true,
                        "name": "id",
                        "in": "path"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Job status",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "enum": ["pending", "processing", "completed", "failed"]
                                        },
                                        "submitted_at": { "type": "string" },
                                        "completed_at": { "type": "string", "nullable": true },
                                        "error_msg": { "type": "string", "nullable": true },
                                        "original_image_id": { "type": "string", "format": "uuid" },
                                        "final_image_id": {
                                            "type": "string",
                                            "nullable": true,
                                            "format": "uuid"
                                        },
                                        "public_id": {
                                            "type": "string",
                                            "nullable": true,
                                            "format": "uuid"
                                        }
                                    },
                                    "required": [
                                        "status",
                                        "submitted_at",
                                        "completed_at",
                                        "error_msg",
                                        "original_image_id",
                                        "final_image_id",
                                        "public_id"
                                    ]
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Not found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": { "error": { "type": "string" } },
                                    "required": ["error"]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/transformations/{id}/publish": {
            "post": {
                "parameters": [
                    {
                        "schema": { "type": "string", "format": "uuid" },
                        "required": true,
                        "name": "id",
                        "in": "path"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Published",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "public_id": { "type": "string", "format": "uuid" }
                                    },
                                    "required": ["public_id"]
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Not found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": { "error": { "type": "string" } },
                                    "required": ["error"]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/transformations/{id}": {
            "delete": {
                "parameters": [
                    {
                        "schema": { "type": "string", "format": "uuid" },
                        "required": true,
                        "name": "id",
                        "in": "path"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Deleted",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": { "success": { "type": "boolean" } },
                                    "required": ["success"]
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Not found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": { "error": { "type": "string" } },
                                    "required": ["error"]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/share/{public_id}": {
            "get": {
                "parameters": [
                    {
                        "schema": { "type": "string", "format": "uuid" },
                        "required": true,
                        "name": "public_id",
                        "in": "path"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Image data",
                        "content": { "image/*": { "schema": { "nullable": true } } }
                    },
                    "404": {
                        "description": "Not found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": { "error": { "type": "string" } },
                                    "required": ["error"]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/images/private/{private_id}": {
            "get": {
                "parameters": [
                    {
                        "schema": { "type": "string", "format": "uuid" },
                        "required": true,
                        "name": "private_id",
                        "in": "path"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Image data",
                        "content": { "image/*": { "schema": { "nullable": true } } }
                    },
                    "404": {
                        "description": "Not found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": { "error": { "type": "string" } },
                                    "required": ["error"]
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
